{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Banger",
  "version": "0.1.0",
  "identifier": "com.djtake2.banger",
  "build": {
    "beforeDevCommand": "npm run bridge",
    "devUrl": "http://localhost:4177",
    "frontendDist": "../public"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Banger",
        "width": 960,
        "height": 720,
        "minWidth": 680,
        "minHeight": 460,
        "resizable": true,
        "alwaysOnTop": true,
        "decorations": false,
        "transparent": true,
        "shadow": true,
        "center": false,
        "skipTaskbar": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": ["icons/icon.png"]
  }
}
